        "sendTo": "={{$json[\"TO\"]}}",
        "subject": "={{ \n  $json[\"TO\"] === \"mnstech@convergeict.com\"\n    ? \"[GNFO-MNS]\"\n    : $json[\"TO\"] === \"enterprisesupport@convergeict.com\"\n      ? \"[GNFO-ES]\"\n      : \"[GNFO]\" \n}}\n {{ $node[\"Submit Form (POST)\"].json[\"body\"][\"issueType\"].toUpperCase() }} | \n {{ $json[\"DEVICE NAME\"] }} | \n {{\n    $node[\"Submit Form (POST)\"].json[\"body\"][\"reason\"] === \"Others\"\n      ? $node[\"Submit Form (POST)\"].json[\"body\"][\"manualReason\"]\n      : $node[\"Submit Form (POST)\"].json[\"body\"][\"reason\"]\n }}",
        "message": "=<p style=\"font-family:Calibri, Arial, sans-serif; font-size:12.5px; color:#000; margin:0 0 6px;\">\n  Hi Team,\n</p>\n\n<p style=\"font-family:Calibri, Arial, sans-serif; font-size:12.5px; color:#000; margin:0 0 14px;\">\n  Good morning, for creation of ticket and for your further checking.\n</p>\n\n<!-- DARK CARD -->\n<div style=\"\n  display:inline-block;\n  font-family:Calibri, Arial, sans-serif;\n  font-size:12.5px;\n  background:#1a1a1a;\n  color:#ffffff;\n  border-radius:8px;\n  padding:16px 20px;\n  margin-bottom:16px;\n  max-width:100%;\n  width:auto;\n  word-wrap:break-word;\n  box-sizing:border-box;\n  box-shadow:0 0 10px rgba(0,195,137,0.25);\n  border:1px solid rgba(0,195,137,0.3);\n\">\n\n  <!-- 100% SILENT ISSUE VARIABLE -->\n  {{ (() => { \n      $json.issueCheck = $node[\"Submit Form (POST)\"].json[\"body\"][\"reason\"]; \n      return \"\" \n  })() }}\n\n  {{$json[\"DEVICE NAME\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Site Name:</strong> ${$json[\"DEVICE NAME\"]}</p>`\n    : \"\"}}\n\n  {{$json[\"ACCOUNT NUMBER\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Account Number:</strong> ${$json[\"ACCOUNT NUMBER\"]}</p>`\n    : \"\"}}\n\n  {{$json[\"CID\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Circuit ID:</strong> ${$json[\"CID\"]}</p>`\n    : \"\"}}\n\n  <!-- Hide Termination if Interface Down -->\n  {{($json.issueCheck !== \"Interface Down\" && $json[\"TERMINATION\"])\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Termination:</strong> ${$json[\"TERMINATION\"]}</p>`\n    : \"\"}}\n\n  <!-- Hide SN if Interface Down -->\n  {{($json.issueCheck !== \"Interface Down\" && $json[\"SERIAL\"])\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">SN:</strong> ${$json[\"SERIAL\"]}</p>`\n    : \"\"}}\n\n  <!-- Device Model only if Interface Down -->\n  {{($json.issueCheck === \"Interface Down\" && $json[\"DEVICE MODEL\"])\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Device Model:</strong> ${$json[\"DEVICE MODEL\"]}</p>`\n    : \"\"}}\n\n  <!-- Managed Device Serial only if Interface Down -->\n  {{($json.issueCheck === \"Interface Down\" && $json[\"MANAGED DEVICE SERIAL\"])\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Managed Device Serial:</strong> ${$json[\"MANAGED DEVICE SERIAL\"]}</p>`\n    : \"\"}}\n\n  {{$json[\"POC\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">POC:</strong> ${$json[\"POC\"]}</p>`\n    : \"\"}}\n\n  {{$json[\"CONTACT NO.\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Contact No.:</strong> ${$json[\"CONTACT NO.\"]}</p>`\n    : \"\"}}\n\n  {{$json[\"ADDRESS\"]\n    ? `<p style=\"margin:0 0 6px;\"><strong style=\"color:#00C389;\">Address:</strong> ${$json[\"ADDRESS\"]}</p>`\n    : \"\"}}\n\n  <p style=\"margin:0;\">\n    <strong style=\"color:#00C389;\">Issue:</strong>\n    {{$json.issueCheck === \"Others\"\n      ? $node[\"Submit Form (POST)\"].json[\"body\"][\"manualReason\"]\n      : $json.issueCheck}}\n  </p>\n\n</div>\n\n<p style=\"font-family:Calibri, Arial, sans-serif; font-size:12.5px; color:#000; margin:16px 0 6px;\">\n  Thank you.\n</p>\n\n<p style=\"font-family:Calibri, Arial, sans-serif; font-size:12.5px; color:#000; margin:0;\">\n  Regards,<br>\n  <span style=\"color:#00C389; font-weight:600;\">\n    {{$node[\"Submit Form (POST)\"].json[\"body\"][\"senderName\"]}}\n  </span><br>\n  Global Network Fulfillment & Ops – Managed Services Group<br>\n  <a href=\"mailto:enhancementservices@convergeict.com\" style=\"color:#0563c1; text-decoration:underline;\">enhancementservices@convergeict.com</a><br>\n  <a href=\"https://www.convergeict.com\" style=\"color:#0563c1; text-decoration:underline;\">www.convergeict.com</a> |\n  <a href=\"https://www.facebook.com/ConvergeICTOfficial\" style=\"color:#0563c1; text-decoration:underline;\">facebook.com/ConvergeICTOfficial</a><br>\n  Reliance IT Center, #99 E. Rodriguez Jr. Avenue, Ugong, Pasig City\n</p>\n\n<p style=\"margin-top:8px;\">\n  <img src=\"https://drive.google.com/uc?export=view&id=1NUQPE6FcnThPZPIpt36jeuU0-pvhftQ7\" \n       alt=\"Converge Logo\" width=\"110\" style=\"vertical-align:middle; margin-right:10px;\">\n  <img src=\"https://drive.google.com/uc?export=view&id=1-rHVYhS7f7Cv7vkh8LSaeDBJekXvZQqq\" \n       alt=\"Managed Services Logo\" width=\"140\" style=\"vertical-align:middle;\">\n</p>\n",
